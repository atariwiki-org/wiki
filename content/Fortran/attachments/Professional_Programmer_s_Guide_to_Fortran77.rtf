{\listtext	\'95	}\
{\listtext	\'95	}named constants\
{\listtext	\'95	}\
{\listtext	\'95	}variables\
{\listtext	\'95	}\
{\listtext	\'95	}array elements\
{\listtext	\'95	}\
{\listtext	\'95	}function references\
{\listtext	\'95	}\
{\listtext	\'95	}complete expressions enclosed in parentheses.\
\pard\pardeftab720\ql\qnatural
